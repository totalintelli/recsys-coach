UPSTAGE_API_KEY=your-key-here
OFFLINE_MODE=false
LLM_BACKEND=upstage  # upstage | llama3 | qwen | vllm
HF_TOKEN=your-huggingface-token-here
LOCAL_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
LLAMA_LOAD_IN_8BIT=true
LLAMA_TEMPERATURE=0.3
LLAMA_MAX_NEW_TOKENS=512
# vllm 백엔드 전용 (LLM_BACKEND=vllm일 때만 사용). CUDA GPU 필요.
VLLM_GPU_MEM_UTIL=0.90
VLLM_MAX_MODEL_LEN=4096
